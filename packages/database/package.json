{
  "name": "@theorie-direkt/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "import:questions": "tsx src/import-questions.ts",
    "import:my-base": "tsx src/import-my-base.ts",
    "questions:clear-demo": "tsx src/clear-demo-questions.ts",
    "questions:auto-topics": "node --import tsx src/auto-topics.ts",
    "catalog:sync-localizations": "node --import tsx src/catalog-sync-localizations.ts",
    "catalog:prune-empty-duplicates": "node --import tsx src/prune-empty-duplicate-topics.ts",
    "translations:export-missing": "node --import tsx src/translations-export-missing.ts",
    "translations:import": "node --import tsx src/translations-import.ts",
    "translations:status": "node --import tsx src/translations-status.ts",
    "translations:split-ru": "node --import tsx src/translations-split-ru.ts",
    "translations:merge-ru": "node --import tsx src/translations-merge-ru.ts",
    "translations:split-tr": "node --import tsx src/translations-split-tr.ts",
    "translations:merge-tr": "node --import tsx src/translations-merge-tr.ts",
    "translations:split-uz": "node --import tsx src/translations-split-uz.ts",
    "translations:merge-uz": "node --import tsx src/translations-merge-uz.ts",
    "db:inspect": "node scripts/db-inspect.mjs",
    "db:repair-questions": "node scripts/db-repair-questions.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "@theorie-direkt/shared": "*",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
