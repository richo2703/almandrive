generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

enum ExamStatus {
  IN_PROGRESS
  FINISHED
  ABANDONED
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  CANCELLED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model User {
  id                  String        @id @default(cuid())
  telegramId          BigInt        @unique
  username            String?
  firstName           String?
  lastName            String?
  interfaceLanguageId String?
  selectedCategoryId  String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  interfaceLanguage   Language?     @relation(fields: [interfaceLanguageId], references: [id])
  selectedCategory    LicenseCategory? @relation(fields: [selectedCategoryId], references: [id])
  answers             UserAnswer[]
  bookmarks           Bookmark[]
  examSessions        ExamSession[]
  subscriptions       Subscription[]
  payments            Payment[]

  @@index([telegramId])
}

model Language {
  id                  String                    @id @default(cuid())
  code                String                    @unique
  name                String
  nativeName          String
  isInterfaceActive   Boolean                   @default(true)
  isContentActive     Boolean                   @default(false)
  isRtl               Boolean                   @default(false)
  questionTranslations QuestionTranslation[]
  optionTranslations  AnswerOptionTranslation[]
  topicTranslations   TopicTranslation[]
  categoryTranslations LicenseCategoryTranslation[]
  users               User[]
}

model LicenseCategory {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  sortOrder   Int
  isActive    Boolean     @default(true)
  questions   Question[]
  users       User[]
  exams       ExamSession[]
  translations LicenseCategoryTranslation[]
}

model LicenseCategoryTranslation {
  id          String          @id @default(cuid())
  categoryId  String
  languageId  String
  name        String
  category    LicenseCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  language    Language        @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([categoryId, languageId])
}

model Topic {
  id           String                @id @default(cuid())
  slug         String                @unique
  sortOrder    Int                   @default(0)
  isActive     Boolean               @default(true)
  questions    Question[]
  translations TopicTranslation[]
}

model TopicTranslation {
  id         String   @id @default(cuid())
  topicId    String
  languageId String
  name       String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([topicId, languageId])
}

model Question {
  id            String                @id @default(cuid())
  externalId    String                @unique
  categoryId    String
  topicId       String
  type          QuestionType
  difficulty    Int                   @default(1)
  imageUrl      String?
  videoUrl      String?
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  category      LicenseCategory       @relation(fields: [categoryId], references: [id])
  topic         Topic                 @relation(fields: [topicId], references: [id])
  translations  QuestionTranslation[]
  answerOptions AnswerOption[]
  userAnswers   UserAnswer[]
  bookmarks     Bookmark[]
  examAnswers   ExamAnswer[]

  @@index([categoryId, topicId, isActive])
}

model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  languageId  String
  text        String
  explanation String?
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([questionId, languageId])
}

model AnswerOption {
  id           String                    @id @default(cuid())
  questionId   String
  key          String
  isCorrect    Boolean                   @default(false)
  sortOrder    Int
  question     Question                  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  translations AnswerOptionTranslation[]

  @@unique([questionId, key])
}

model AnswerOptionTranslation {
  id             String       @id @default(cuid())
  answerOptionId String
  languageId     String
  text           String
  answerOption   AnswerOption @relation(fields: [answerOptionId], references: [id], onDelete: Cascade)
  language       Language     @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([answerOptionId, languageId])
}

model UserAnswer {
  id                String   @id @default(cuid())
  userId            String
  questionId        String
  selectedOptionIds String[]
  isCorrect         Boolean
  answeredAt        DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question          Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId, questionId, answeredAt])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model ExamSession {
  id            String          @id @default(cuid())
  userId        String
  categoryId    String
  status        ExamStatus      @default(IN_PROGRESS)
  questionIds   String[]
  score         Int?
  totalQuestions Int
  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      LicenseCategory @relation(fields: [categoryId], references: [id])
  answers       ExamAnswer[]

  @@index([userId, status])
}

model ExamAnswer {
  id                String      @id @default(cuid())
  examSessionId     String
  questionId        String
  selectedOptionIds String[]
  isCorrect         Boolean
  answeredAt        DateTime    @default(now())
  examSession       ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  question          Question    @relation(fields: [questionId], references: [id])

  @@unique([examSessionId, questionId])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String
  status            SubscriptionStatus @default(INACTIVE)
  provider          String?
  externalId        String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  amountCents Int
  currency   String        @default("EUR")
  status     PaymentStatus @default(PENDING)
  provider   String?
  externalId String?       @unique
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}
